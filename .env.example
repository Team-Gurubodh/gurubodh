# Copy this file to '.env' and fill in the values below to get started.

# Database Credentials
DATABASE_CLIENT=postgres
DATABASE_HOST=database
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD= # Set a strong password here

# PostgreSQL Role Passwords (used by database/init/*.sql scripts)
# These are referenced as $PWD_<role_name> environment variables
PWD_db_admin=        # Superuser-level admin password
PWD_strapi=          # Database owner password
PWD_strapi_app=      # Application login password
PWD_strapi_schema_migrator=  # Migration runner password

# S3 Object Storage Credentials (for PDF, Audio, and Doc storage)
AWS_ACCESS_KEY_ID= # Your AWS Access Key
AWS_ACCESS_SECRET= # Your AWS Secret Key
AWS_REGION=us-east-1
AWS_BUCKET= # Your bucket name

# Strapi App Settings
NODE_ENV=development
APP_KEYS= # Generate a random string for app keys
API_TOKEN_SALT= # Generate a random string for API tokens
ADMIN_JWT_SECRET= # Generate a random string for JWT secret