{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gurubodh.local/schemas/jobs/generate_chunks_job.schema.json",
  "title": "Gurubodh generate-chunks job",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pipeline", "source", "destination", "naming", "chunking"],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "pipeline": {
      "const": "generate-chunks"
    },
    "source": {
      "$ref": "#/$defs/subjectArtifactLocation"
    },
    "destination": {
      "$ref": "#/$defs/subjectArtifactLocation"
    },
    "naming": {
      "$ref": "#/$defs/naming"
    },
    "chunking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "model_revision",
        "embedding_mode",
        "embedding_dimension",
        "threshold_percentile",
        "min_chars",
        "window_size",
        "batch_size",
        "normalize_embeddings",
        "device",
        "local_files_only"
      ],
      "properties": {
        "provider": {
          "const": "semantic-chunking"
        },
        "model": {
          "const": "BAAI/bge-m3"
        },
        "model_revision": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "embedding_mode": {
          "const": "dense"
        },
        "embedding_dimension": {
          "const": 1024
        },
        "threshold_percentile": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "min_chars": {
          "type": "integer",
          "minimum": 0
        },
        "window_size": {
          "type": "integer",
          "minimum": 1
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1
        },
        "normalize_embeddings": {
          "type": "boolean"
        },
        "device": {
          "type": ["string", "null"],
          "enum": ["cpu", "mps", "cuda", null]
        },
        "local_files_only": {
          "type": "boolean"
        }
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{3}$"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "subjectArtifactLocation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["backend", "root_dir", "subject_dir"],
          "properties": {
            "backend": {
              "const": "local"
            },
            "root_dir": {
              "type": "string",
              "minLength": 1
            },
            "subject_dir": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["backend", "bucket", "prefix", "subject_dir", "url_base"],
          "properties": {
            "backend": {
              "const": "r2"
            },
            "bucket": {
              "type": "string",
              "minLength": 1
            },
            "prefix": {
              "type": "string",
              "minLength": 1
            },
            "subject_dir": {
              "type": "string",
              "minLength": 1
            },
            "url_base": {
              "type": ["string", "null"]
            }
          }
        }
      ]
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category_code", "subject_code", "title_slug", "version", "subversion"],
      "properties": {
        "category_code": {
          "type": "string",
          "pattern": "^CAT[0-9]{3}$"
        },
        "subject_code": {
          "type": "string",
          "pattern": "^SUB[0-9]{3}$"
        },
        "title_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "subversion": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        }
      }
    }
  }
}
