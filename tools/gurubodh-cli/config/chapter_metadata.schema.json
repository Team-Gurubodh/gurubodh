{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gurubodh.local/schemas/chapter_metadata.schema.json",
  "title": "Gurubodh Chapter Metadata",
  "type": "object",
  "required": [
    "schema_version",
    "document",
    "files",
    "storage",
    "processing",
    "conversion",
    "integrity",
    "content_stats",
    "content",
    "annotations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.2.0"
    },
    "document": {
      "type": "object",
      "required": [
        "category_code",
        "subject_code",
        "title_slug",
        "chapter_number",
        "version",
        "language"
      ],
      "properties": {
        "category_code": {
          "type": "string",
          "pattern": "^CAT[0-9]{3}$"
        },
        "subject_code": {
          "type": "string",
          "pattern": "^SUB[0-9]{3}$"
        },
        "title_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"
        },
        "chapter_number": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]{2}\\.[0-9]{2}$"
        },
        "language": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "object",
      "required": [
        "metadata_filename",
        "text_filename",
        "msword_filename"
      ],
      "properties": {
        "metadata_filename": {
          "type": "string",
          "minLength": 1
        },
        "text_filename": {
          "type": "string",
          "minLength": 1
        },
        "msword_filename": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "required": ["source", "artifacts"],
      "properties": {
        "source": {
          "$ref": "#/$defs/storage_reference"
        },
        "artifacts": {
          "type": "object",
          "required": [
            "metadata",
            "text",
            "msword",
            "full_subject_msword",
            "full_subject_text"
          ],
          "properties": {
            "metadata": {
              "$ref": "#/$defs/storage_reference"
            },
            "text": {
              "$ref": "#/$defs/storage_reference"
            },
            "msword": {
              "$ref": "#/$defs/storage_reference"
            },
            "full_subject_msword": {
              "$ref": "#/$defs/storage_reference"
            },
            "full_subject_text": {
              "$ref": "#/$defs/storage_reference"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "processing": {
      "type": "object",
      "required": ["pipeline", "entry_point"],
      "properties": {
        "pipeline": {
          "type": "string",
          "enum": ["legacy-docx-to-unicode", "unicode-docx-ingest"]
        },
        "entry_point": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "conversion": {
      "type": "object",
      "required": [
        "created_at",
        "source_font_encoding",
        "source_file_format",
        "output_text_encoding",
        "converter_counts"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_font_encoding": {
          "type": "string",
          "minLength": 1
        },
        "source_file_format": {
          "type": "string",
          "minLength": 1
        },
        "output_text_encoding": {
          "type": "string",
          "minLength": 1
        },
        "converter_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "object",
              "required": [
                "algorithm",
                "encoding",
                "line_endings",
                "scope",
                "value"
              ],
              "properties": {
                "algorithm": {
                  "type": "string",
                  "const": "sha256"
                },
                "encoding": {
                  "type": "string",
                  "const": "UTF-8"
                },
                "line_endings": {
                  "type": "string",
                  "const": "LF"
                },
                "scope": {
                  "type": "string",
                  "const": "artifact-bytes"
                },
                "value": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "content_stats": {
      "type": "object",
      "required": ["word_count", "character_count", "paragraph_count"],
      "properties": {
        "word_count": {
          "type": "integer",
          "minimum": 0
        },
        "character_count": {
          "type": "integer",
          "minimum": 0
        },
        "paragraph_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "required": ["title", "summary", "automated_tags", "scriptural_terms"],
      "properties": {
        "title": {
          "type": ["string", "null"]
        },
        "summary": {
          "type": ["string", "null"]
        },
        "automated_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "scriptural_terms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "annotations": {
      "type": "object",
      "required": ["expert_descriptors", "user_tags"],
      "properties": {
        "expert_descriptors": {
          "type": "object",
          "propertyNames": {
            "minLength": 1
          },
          "additionalProperties": {
            "type": ["string", "number", "boolean", "array", "object", "null"]
          },
          "default": {}
        },
        "user_tags": {
          "type": "object",
          "required": ["labels", "custom_notes"],
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "custom_notes": {
              "type": ["string", "null"],
              "default": null
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "paragraph_segmentation": {
      "$ref": "#/$defs/paragraph_segmentation"
    }
  },
  "$defs": {
    "paragraph_segmentation": {
      "type": "object",
      "required": ["enabled", "status"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "const": "semantic-chunking"
        },
        "model": {
          "type": "string",
          "const": "BAAI/bge-m3"
        },
        "embedding_mode": {
          "type": "string",
          "const": "dense"
        },
        "embedding_dimension": {
          "type": "integer",
          "const": 1024
        },
        "strategy_version": {
          "type": "string",
          "const": "semantic-window-v1"
        },
        "status": {
          "type": "string",
          "enum": ["disabled", "segmented", "skipped-unchanged", "failed"]
        },
        "source_text_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "index_unit": {
          "type": "string",
          "const": "python-codepoint"
        },
        "span_semantics": {
          "type": "string",
          "const": "zero-based-end-exclusive"
        },
        "parameters": {
          "type": "object",
          "required": [
            "threshold_percentile",
            "min_chars",
            "window_size",
            "batch_size",
            "normalize_embeddings",
            "device"
          ],
          "properties": {
            "threshold_percentile": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "min_chars": {
              "type": "integer",
              "minimum": 0
            },
            "window_size": {
              "type": "integer",
              "minimum": 1
            },
            "batch_size": {
              "type": "integer",
              "minimum": 1
            },
            "normalize_embeddings": {
              "type": "boolean"
            },
            "device": {
              "type": ["string", "null"],
              "enum": ["cpu", "mps", "cuda", null]
            }
          },
          "additionalProperties": false
        },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["index", "sentence_count", "char_count", "chunk_text_sha256"],
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 1
              },
              "sentence_count": {
                "type": "integer",
                "minimum": 0
              },
              "char_count": {
                "type": "integer",
                "minimum": 0
              },
              "start_char": {
                "type": "integer",
                "minimum": 0
              },
              "end_char": {
                "type": "integer",
                "minimum": 0
              },
              "chunk_text_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false
          }
        },
        "diagnostics": {
          "type": "object",
          "properties": {
            "breakpoint_threshold": {
              "type": ["number", "null"]
            },
            "warning": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "status": {
                "const": "disabled"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "segmented"
              }
            }
          },
          "then": {
            "required": [
              "provider",
              "model",
              "embedding_mode",
              "embedding_dimension",
              "strategy_version",
              "source_text_sha256",
              "index_unit",
              "span_semantics",
              "parameters",
              "chunks",
              "diagnostics"
            ]
          }
        }
      ],
      "additionalProperties": false
    },
    "storage_reference": {
      "type": "object",
      "required": ["backend", "url"],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["local", "r2"]
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": ["string", "null"]
        }
      },
      "oneOf": [
        {
          "properties": {
            "backend": {
              "const": "local"
            }
          },
          "required": ["path"],
          "not": {
            "anyOf": [
              {
                "required": ["bucket"]
              },
              {
                "required": ["key"]
              }
            ]
          }
        },
        {
          "properties": {
            "backend": {
              "const": "r2"
            }
          },
          "required": ["bucket", "key"],
          "not": {
            "required": ["path"]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
