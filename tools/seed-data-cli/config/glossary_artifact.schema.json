{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gurubodh.local/schemas/glossary_artifact.schema.json",
  "title": "Gurubodh Glossary Seed-Data Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow",
    "source",
    "strapi",
    "records"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "workflow": {
      "const": "glossary"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "strapi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_type",
        "display_name"
      ],
      "properties": {
        "collection_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "term_code",
          "term",
          "definition"
        ],
        "properties": {
          "term_code": {
            "type": "string",
            "pattern": "^T[0-9]{5}$"
          },
          "term": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
