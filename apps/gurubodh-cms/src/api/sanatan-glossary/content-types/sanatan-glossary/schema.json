{
  "kind": "collectionType",
  "collectionName": "sanatan_glossaries",
  "info": {
    "singularName": "sanatan-glossary",
    "pluralName": "sanatan-glossaries",
    "displayName": "Sanatan Glossary"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "code": {
      "type": "string",
      "maxLength": 6,
      "required": true,
      "unique": true,
      "regex": "^T[0-9]{5}$"
    },
    "term": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "definition": {
      "type": "text",
      "required": true
    }
  }
}
